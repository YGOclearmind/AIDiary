button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

page {
  --warm-bg: #FFF9F2;
  --warm-bg-card: #FFFFFF;
  --warm-bg-input: #F5EFE8;
  --warm-bg-seg: #F0EAE0;
  --warm-text: #2D2A26;
  --warm-text-sec: #5A5048;
  --warm-text-muted: #A09080;
  --warm-text-light: #B0A090;
  --warm-text-placeholder: #C0B0A0;
  --warm-accent: #E8A040;
  --warm-accent-dark: #C08030;
  --warm-border: #E8DDD0;
  --warm-border-light: #F0EAE0;
  --warm-shadow: rgba(212, 196, 176, 0.12);
  --warm-shadow-card: rgba(212, 196, 176, 0.2);
  --warm-tag-orange-bg: #FFF0E0;
  --warm-tag-orange-text: #C08030;
  --warm-tag-green-bg: #E8F4E0;
  --warm-tag-green-text: #508040;
  --warm-tag-blue-bg: #E0E8F8;
  --warm-tag-blue-text: #4060A0;

  background: var(--warm-bg);
  color: var(--warm-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'PingFang SC', sans-serif;
}