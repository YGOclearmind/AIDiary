.page {
  width: 100%;
  min-height: 100vh;
  background: var(--warm-bg);
  box-sizing: border-box;
  overflow-x: hidden;
}

.scroll-area {
  padding: 88rpx 40rpx 0;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 0;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--warm-text);
}

.header-avatar {
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
}

.avatar-btn {
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 72rpx;
  min-height: 72rpx;
  max-height: 72rpx;
  border-radius: 36rpx;
  background: #E8DDD0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 0;
  box-sizing: border-box;
  flex: none;
  flex-shrink: 0;
}

.avatar-button-reset {
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 72rpx;
  min-height: 72rpx;
  max-height: 72rpx;
  margin: 0;
  padding: 0;
  line-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  flex-shrink: 0;
  background: #E8DDD0;
  border-radius: 36rpx;
}

.avatar-button-reset::after {
  border: none;
}

.avatar-img {
  width: 72rpx;
  height: 72rpx;
  display: block;
  border-radius: 36rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 26rpx;
  color: var(--warm-text-muted);
  font-weight: 600;
}

.segment-control {
  margin-top: 40rpx;
  display: flex;
  height: 92rpx;
  background: var(--warm-bg-seg);
  border-radius: 46rpx;
  padding: 6rpx;
  align-items: center;
  gap: 8rpx;
}

.seg-tab {
  flex: 1;
  height: 100%;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.seg-tab-active {
  background: var(--warm-bg-card);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.seg-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--warm-text-muted);
}

.seg-tab-active .seg-text {
  color: var(--warm-text);
  font-weight: 600;
}

.ai-summary-card {
  margin-top: 40rpx;
  border-radius: 40rpx;
  background: var(--warm-bg-card);
  border: 2rpx solid rgba(240, 234, 224, 0.06);
  box-shadow: 0 8rpx 32rpx var(--warm-shadow-card);
  overflow: hidden;
  will-change: transform, opacity;
}

.card-animating {
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease;
}

.card-cover {
  height: 260rpx;
  background: linear-gradient(135deg, #FFECD2 0%, #F8E1F4 40%, #D4E7FE 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  position: relative;
}

.cover-emoji {
  font-size: 80rpx;
}

.cover-period {
  font-size: 24rpx;
  color: #8070A0;
  font-weight: 500;
}

.card-body {
  padding: 36rpx;
}

.ai-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.ai-sparkle {
  font-size: 24rpx;
}

.ai-label-text {
  font-size: 26rpx;
  color: #6B5B8A;
  font-weight: 600;
}

.state-text {
  font-size: 26rpx;
  color: var(--warm-text-muted);
  line-height: 1.6;
}

.summary-text {
  display: block;
  font-size: 26rpx;
  color: #5A5048;
  line-height: 1.6;
}

.divider {
  height: 2rpx;
  background: var(--warm-border-light);
  margin: 32rpx 0;
}

.themes-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-label {
  font-size: 24rpx;
  color: var(--warm-text-muted);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.theme-tags {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.theme-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
}

.tag-orange {
  background: var(--warm-tag-orange-bg);
}

.tag-green {
  background: var(--warm-tag-green-bg);
}

.tag-blue {
  background: var(--warm-tag-blue-bg);
}

.tag-emoji {
  font-size: 24rpx;
}

.tag-text {
  font-size: 22rpx;
  font-weight: 500;
}

.tag-orange .tag-text {
  color: var(--warm-tag-orange-text);
}

.tag-green .tag-text {
  color: var(--warm-tag-green-text);
}

.tag-blue .tag-text {
  color: var(--warm-tag-blue-text);
}

.highlights-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.highlight-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.highlight-dot {
  font-size: 22rpx;
  color: var(--warm-accent);
  flex-shrink: 0;
  line-height: 1.5;
}

.highlight-text {
  font-size: 25rpx;
  color: #5A5048;
  line-height: 1.5;
}

.swipe-hint {
  margin-top: 32rpx;
  text-align: center;
  animation: hintFade 4s ease forwards;
}

.swipe-hint-text {
  font-size: 22rpx;
  color: var(--warm-text-muted);
  letter-spacing: 2rpx;
}

.cal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.cal-popup {
  width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.cal-arrow {
  font-size: 36rpx;
  color: var(--warm-text-muted);
  padding: 8rpx 20rpx;
}

.cal-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 40rpx;
}

.cal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--warm-text);
}

.cal-today-btn {
  font-size: 22rpx;
  color: var(--warm-accent);
  padding: 6rpx 16rpx;
  background: rgba(232, 160, 64, 0.1);
  border-radius: 16rpx;
}

.cal-weekdays {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.cal-wd {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #C0B0A0;
  font-weight: 500;
}

.cal-weeks {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cal-week {
  display: flex;
  justify-content: space-around;
}

.cal-day {
  flex: 1;
  height: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 16rpx;
}

.cal-day-text {
  font-size: 26rpx;
  color: #5A5048;
}

.cal-day-other .cal-day-text {
  color: #C0B0A0;
}

.cal-day-today .cal-day-text {
  color: var(--warm-accent);
  font-weight: 700;
}

.cal-day-selected {
  background: linear-gradient(135deg, #FFF5E6 0%, #FFECD2 100%);
}

.cal-day-selected .cal-day-text {
  color: var(--warm-accent-dark);
  font-weight: 700;
}

.cal-day-future .cal-day-text {
  color: #D8D0C8;
}

.cal-day-has .cal-day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: var(--warm-accent);
  position: absolute;
  bottom: 4rpx;
}

@keyframes hintFade {
  0% { opacity: 0; }
  10% { opacity: 1; }
  70% { opacity: 1; }
  100% { opacity: 0; }
}

.bottom-spacer {
  height: 40rpx;
}
