.container {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 22rpx 120rpx;
  box-sizing: border-box;
  color: var(--aid-text);
}

.title {
  font-size: 44rpx;
  font-weight: 800;
}

.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.seg-mini {
  display: flex;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  gap: 6rpx;
}

.seg-mini-item {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.seg-mini-item-active {
  background: #fff;
  color: #24211d;
}

.switch-bar {
  margin-top: 12rpx;
  display: flex;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  gap: 6rpx;
}

.switch-item {
  flex: 1;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  border-radius: 999rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.switch-item-active {
  background: #fff;
  color: var(--aid-text);
}

.content-swiper {
  margin-top: 12rpx;
  height: 1020rpx;
}

.kpi-row {
  display: flex;
  gap: 12rpx;
}

.kpi-item {
  flex: 1;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid var(--aid-line);
  padding: 16rpx;
}

.kpi-label {
  display: block;
  color: var(--aid-muted);
  font-size: 20rpx;
  font-weight: 700;
}

.kpi-value {
  display: block;
  margin-top: 6rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.kpi-delta {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #5b8a6b;
  font-weight: 700;
}

.card {
  margin-top: 12rpx;
  border-radius: 32rpx;
  background: #fff;
  border: 1rpx solid var(--aid-line);
  box-shadow: var(--aid-shadow);
  padding: 20rpx;
}

.row-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 800;
}

.card-meta {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  font-size: 20rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.bars {
  margin-top: 8rpx;
  height: 120rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.bar {
  flex: 1;
  background: #ff8a4b;
  border-radius: 8rpx;
}

.h1 { height: 34rpx; }
.h2 { height: 62rpx; }
.h3 { height: 48rpx; }
.h4 { height: 78rpx; }
.h5 { height: 58rpx; }
.h6 { height: 92rpx; }
.h7 { height: 40rpx; }

.legend {
  margin-top: 8rpx;
  display: flex;
  justify-content: space-between;
  color: var(--aid-muted);
  font-size: 18rpx;
  font-weight: 700;
}

.report-card {
  margin-top: 12rpx;
  border-radius: 32rpx;
  padding: 20rpx;
  background: linear-gradient(160deg, #24211d 0%, #3c342e 100%);
}

.report-subtitle {
  display: block;
  color: #ffffffcc;
  font-size: 20rpx;
  font-weight: 700;
}

.report-title {
  display: block;
  margin-top: 8rpx;
  color: #fff;
  font-size: 26rpx;
  line-height: 1.6;
  font-weight: 800;
}

.chip-row {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
}

.chip-row .chip {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #ffffff1a;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.summary-buttons {
  margin-top: 12rpx;
  display: flex;
  gap: 8rpx;
}

.year-selector {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.year-label {
  font-size: 21rpx;
  color: #ffffffcc;
  font-weight: 700;
}

.year-picker-value {
  min-width: 150rpx;
  text-align: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff1a;
  color: #fff;
  font-size: 21rpx;
  font-weight: 700;
}

.summary-btn {
  flex: 1;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.summary-btn::after {
  border: none;
}

.summary-btn-accent {
  background: #ff8a4b;
  color: #fff;
}

.summary-btn-light {
  background: #ffffff1a;
  color: #fff;
}

.summary-scroll {
  max-height: 760rpx;
}

.summary-item {
  padding: 16rpx 10rpx;
  border-bottom: 1rpx solid var(--aid-line);
  background: transparent;
}

.summary-item:last-child {
  border-bottom: none;
}

.summary-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.summary-item-title {
  font-size: 24rpx;
  font-weight: 700;
}

.summary-item-date {
  font-size: 19rpx;
  color: var(--aid-muted);
}

.summary-item-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8rpx;
}

.copy-btn {
  margin: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  font-size: 20rpx;
  display: flex;
  align-items: center;
}

.copy-btn::after {
  border: none;
}

.delete-btn {
  margin: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #ff8a4b1a;
  color: #ff8a4b;
  font-size: 20rpx;
  display: flex;
  align-items: center;
}

.delete-btn::after {
  border: none;
}

.copy-btn-text {
  font-size: 20rpx;
}

.empty-state {
  padding: 48rpx 18rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--aid-muted);
  line-height: 1.6;
}

.guide-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.guide-item {
  display: block;
  font-size: 22rpx;
  color: #3f3a34;
  line-height: 1.7;
  margin-bottom: 8rpx;
  font-weight: 600;
}
