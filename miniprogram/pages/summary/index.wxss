.page {
  width: 100%;
  min-height: 100vh;
  background: var(--warm-bg);
  box-sizing: border-box;
  overflow-x: hidden;
}

.scroll-area {
  padding: 88rpx 40rpx 0;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 0;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--warm-text);
}

.share-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: var(--warm-bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-icon {
  font-size: 28rpx;
  color: var(--warm-text-muted);
}

.segment-control {
  margin-top: 40rpx;
  display: flex;
  height: 84rpx;
  background: var(--warm-bg-seg);
  border-radius: 42rpx;
  padding: 6rpx;
  align-items: center;
}

.seg-tab {
  flex: 1;
  height: 100%;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.seg-tab-active {
  background: var(--warm-bg-card);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.seg-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--warm-text-muted);
}

.seg-tab-active .seg-text {
  color: var(--warm-text);
  font-weight: 600;
}

.ai-summary-card {
  margin-top: 40rpx;
  border-radius: 40rpx;
  background: var(--warm-bg-card);
  border: 2rpx solid rgba(240, 234, 224, 0.06);
  box-shadow: 0 8rpx 32rpx var(--warm-shadow-card);
  overflow: hidden;
  will-change: transform, opacity;
}

.card-animating {
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease;
}

.card-cover {
  height: 260rpx;
  background: linear-gradient(135deg, #FFECD2 0%, #F8E1F4 40%, #D4E7FE 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.cover-emoji {
  font-size: 80rpx;
}

.cover-period {
  font-size: 24rpx;
  color: #8070A0;
  font-weight: 500;
}

.card-body {
  padding: 36rpx;
}

.ai-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.ai-sparkle {
  font-size: 24rpx;
}

.ai-label-text {
  font-size: 26rpx;
  color: #6B5B8A;
  font-weight: 600;
}

.state-text {
  font-size: 26rpx;
  color: var(--warm-text-muted);
  line-height: 1.6;
}

.summary-text {
  display: block;
  font-size: 26rpx;
  color: #5A5048;
  line-height: 1.6;
}

.divider {
  height: 2rpx;
  background: var(--warm-border-light);
  margin: 32rpx 0;
}

.themes-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-label {
  font-size: 24rpx;
  color: var(--warm-text-muted);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.theme-tags {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.theme-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
}

.tag-orange {
  background: var(--warm-tag-orange-bg);
}

.tag-green {
  background: var(--warm-tag-green-bg);
}

.tag-blue {
  background: var(--warm-tag-blue-bg);
}

.tag-emoji {
  font-size: 24rpx;
}

.tag-text {
  font-size: 22rpx;
  font-weight: 500;
}

.tag-orange .tag-text {
  color: var(--warm-tag-orange-text);
}

.tag-green .tag-text {
  color: var(--warm-tag-green-text);
}

.tag-blue .tag-text {
  color: var(--warm-tag-blue-text);
}

.highlights-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.highlight-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.highlight-dot {
  font-size: 22rpx;
  color: var(--warm-accent);
  flex-shrink: 0;
  line-height: 1.5;
}

.highlight-text {
  font-size: 25rpx;
  color: #5A5048;
  line-height: 1.5;
}

.swipe-hint {
  margin-top: 32rpx;
  text-align: center;
  animation: hintFade 4s ease forwards;
}

.swipe-hint-text {
  font-size: 22rpx;
  color: var(--warm-text-muted);
  letter-spacing: 2rpx;
}

@keyframes hintFade {
  0% { opacity: 0; }
  10% { opacity: 1; }
  70% { opacity: 1; }
  100% { opacity: 0; }
}

.bottom-spacer {
  height: 40rpx;
}