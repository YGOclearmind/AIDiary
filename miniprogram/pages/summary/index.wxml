<view class="page">
  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="false" scroll-x="false" enable-flex>
    <view class="header">
      <text class="header-title">洞察</text>
      <view class="share-btn">
        <text class="share-icon">↗</text>
      </view>
    </view>

    <view class="segment-control">
      <view 
        class="seg-tab {{currentPeriod === 'day' ? 'seg-tab-active' : ''}}" 
        data-period="day" 
        bindtap="selectPeriod"
      >
        <text class="seg-text">昨日</text>
      </view>
      <view 
        class="seg-tab {{currentPeriod === 'week' ? 'seg-tab-active' : ''}}" 
        data-period="week" 
        bindtap="selectPeriod"
      >
        <text class="seg-text">上周</text>
      </view>
      <view 
        class="seg-tab {{currentPeriod === 'year' ? 'seg-tab-active' : ''}}" 
        data-period="year" 
        bindtap="selectPeriod"
      >
        <text class="seg-text">去年</text>
      </view>
    </view>

    <view class="ai-summary-card">
      <view class="card-cover">
        <text class="cover-emoji">🌸</text>
        <text class="cover-period">{{periodLabel}}</text>
      </view>
      <view class="card-body">
        <view class="ai-label">
          <text class="ai-sparkle">✨</text>
          <text class="ai-label-text">AI {{periodName}}摘要</text>
        </view>
        <view wx:if="{{summaryLoading}}" class="state-text">内容加载中...</view>
        <view wx:elif="{{summaryError}}" class="state-text">{{summaryError}}</view>
        <text wx:else class="summary-text">{{summaryText}}</text>

        <view class="divider"></view>

        <view wx:if="{{themeTags.length}}" class="themes-section">
          <text class="section-label">关键主题</text>
          <view class="theme-tags">
            <view wx:for="{{themeTags}}" wx:key="name" class="theme-tag {{item.cls}}">
              <text class="tag-emoji">{{item.emoji}}</text>
              <text class="tag-text">{{item.name}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{highlights.length}}" class="divider"></view>

        <view wx:if="{{highlights.length}}" class="highlights-section">
          <text class="section-label">精彩集锦</text>
          <view wx:for="{{highlights}}" wx:key="*this" class="highlight-item">
            <text class="highlight-dot">✦</text>
            <text class="highlight-text">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>
</view>
