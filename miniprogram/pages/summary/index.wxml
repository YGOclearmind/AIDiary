<view class="page">
  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="false" scroll-x="false" enable-flex>
    <view class="header">
      <view class="header-left">
        <text class="header-title">洞察</text>
      </view>
      <view class="header-avatar">
        <button wx:if="{{chooseAvatarSupported}}" class="avatar-btn avatar-button-reset" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{hasAvatarImage}}" class="avatar-img" src="{{avatarDisplayUrl}}" mode="aspectFill" />
          <text wx:else class="avatar-text">S</text>
        </button>
        <view wx:else class="avatar-btn">
          <image wx:if="{{hasAvatarImage}}" class="avatar-img" src="{{avatarDisplayUrl}}" mode="aspectFill" />
          <text wx:else class="avatar-text">S</text>
        </view>
      </view>
    </view>

    <view class="segment-control">
      <view
        class="seg-tab {{currentPeriod === 'day' ? 'seg-tab-active' : ''}}"
        data-period="day"
        bindtap="selectPeriod"
      >
        <text class="seg-text">日报</text>
      </view>
      <view
        class="seg-tab {{currentPeriod === 'week' ? 'seg-tab-active' : ''}}"
        data-period="week"
        bindtap="selectPeriod"
      >
        <text class="seg-text">周报</text>
      </view>
    </view>

    <view 
      class="ai-summary-card {{cardAnimating ? 'card-animating' : ''}}" 
      style="transform: translateX({{cardTranslateX}}px); opacity: {{cardOpacity}};"
      bindtouchstart="onTouchStart" 
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    >
      <view class="card-cover" bindtap="openCalendar">
        <text class="cover-emoji">{{coverEmoji}}</text>
        <text class="cover-period">{{periodLabel}}</text>
      </view>
      <view class="card-body">
        <view class="ai-label">
          <text class="ai-sparkle">✨</text>
          <text class="ai-label-text">AI {{periodName}}摘要</text>
        </view>
        <view wx:if="{{summaryLoading}}" class="state-text">内容加载中...</view>
        <view wx:elif="{{summaryError}}" class="state-text">{{summaryError}}</view>
        <text wx:else class="summary-text">{{summaryText}}</text>

        <view class="divider"></view>

        <view wx:if="{{themeTags.length}}" class="themes-section">
          <text class="section-label">关键主题</text>
          <view class="theme-tags">
            <view wx:for="{{themeTags}}" wx:key="name" class="theme-tag {{item.cls}}">
              <text class="tag-emoji">{{item.emoji}}</text>
              <text class="tag-text">{{item.name}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{highlights.length}}" class="divider"></view>

        <view wx:if="{{highlights.length}}" class="highlights-section">
          <text class="section-label">精彩集锦</text>
          <view wx:for="{{highlights}}" wx:key="*this" class="highlight-item">
            <text class="highlight-dot">✦</text>
            <text class="highlight-text">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="swipe-hint" wx:if="{{showSwipeHint}}">
      <text class="swipe-hint-text">← 左右滑动切换时间 →</text>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>

  <view wx:if="{{showCalendar}}" class="cal-mask" bindtap="closeCalendar">
    <view class="cal-popup" catchtap="preventTap">
      <view class="cal-header">
        <text class="cal-arrow" bindtap="calPrevMonth">‹</text>
        <view class="cal-title-wrap">
          <text class="cal-title">{{calTitle}}</text>
          <text class="cal-today-btn" bindtap="goToToday">返回今日</text>
        </view>
        <text class="cal-arrow" bindtap="calNextMonth">›</text>
      </view>
      <view class="cal-weekdays">
        <text class="cal-wd" wx:for="{{calWeekDays}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="cal-weeks">
        <view class="cal-week" wx:for="{{calDays}}" wx:key="weekIndex">
          <view
            class="cal-day {{item2.isCurrentMonth ? '' : 'cal-day-other'}} {{item2.isToday ? 'cal-day-today' : ''}} {{item2.isSelected ? 'cal-day-selected' : ''}} {{item2.hasRecord ? 'cal-day-has' : ''}} {{item2.isFuture ? 'cal-day-future' : ''}}"
            wx:for="{{item.days}}"
            wx:for-item="item2"
            wx:key="dateStr"
            bindtap="onCalDayTap"
            data-date="{{item2.dateStr}}"
          >
            <text class="cal-day-text">{{item2.day || ''}}</text>
            <view wx:if="{{item2.hasRecord}}" class="cal-day-dot"></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
