<view class="container">
  <view class="header">
    <text class="title">智能总结</text>
    <text class="subtitle">按分类整理你的碎碎念</text>
  </view>

  <view class="summary-section section-card">
    <view class="section-head">
      <text class="section-title">快速生成</text>
      <text class="section-tag">AI 驱动</text>
    </view>
    <view class="year-selector">
      <text class="year-label">年报年份</text>
      <picker mode="selector" range="{{yearOptions}}" value="{{selectedYearIndex}}" bindchange="onYearChange">
        <view class="year-picker-value">{{selectedYear}}年</view>
      </picker>
    </view>
    <view class="summary-buttons">
      <button class="summary-btn summary-btn-daily" bindtap="getDailySummary">
        <text class="summary-btn-icon">📅</text>
        <text class="summary-btn-text">每日条目总结</text>
        <text class="summary-btn-desc">按分类陈述当天碎碎念</text>
      </button>
      <button class="summary-btn summary-btn-weekly" bindtap="getWeeklySummary">
        <text class="summary-btn-icon">📊</text>
        <text class="summary-btn-text">每周条目总结</text>
        <text class="summary-btn-desc">按分类陈述当周碎碎念</text>
      </button>
      <button class="summary-btn summary-btn-yearly" bindtap="getYearlySummary">
        <text class="summary-btn-icon">🧭</text>
        <text class="summary-btn-text">年度条目总结</text>
        <text class="summary-btn-desc">提取全年主轴并做压缩总结</text>
      </button>
    </view>
  </view>

  <view class="history-section section-card">
    <view class="section-head">
      <text class="section-title">历史总结</text>
      <text class="records-count">{{summaryHistory.length}} 条</text>
    </view>
    <scroll-view class="summary-scroll" scroll-y enhanced show-scrollbar="false">
      <view wx:if="{{summaryHistory.length > 0}}">
        <view class="summary-item" wx:for="{{summaryHistory}}" wx:key="_id" bindtap="openSummaryDetail" data-id="{{item._id}}">
          <view class="summary-item-header">
            <text class="summary-item-title">{{item.historyTitle}}</text>
            <text class="summary-item-date">点击查看</text>
          </view>
          <view class="summary-item-footer">
            <button class="copy-btn" catchtap="copySummary" data-id="{{item._id}}">
              <text class="copy-btn-icon">📋</text>
              <text class="copy-btn-text">复制</text>
            </button>
            <button class="delete-btn" catchtap="deleteSummary" data-id="{{item._id}}">
              <text class="copy-btn-icon">🗑</text>
              <text class="copy-btn-text">删除</text>
            </button>
          </view>
        </view>
      </view>
      <view wx:else class="empty-state">
        <text class="empty-title">暂无历史总结</text>
        <text class="empty-desc">生成总结后，历史记录会显示在这里</text>
      </view>
    </scroll-view>
  </view>

</view>
