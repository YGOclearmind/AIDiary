<view class="page">
  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="false" scroll-x="false" enable-flex>
    <view class="header">
      <text class="header-title">洞察</text>
      <view class="share-btn">
        <text class="share-icon">↗</text>
      </view>
    </view>

    <view class="segment-control">
      <view 
        class="seg-tab {{currentPeriod === 'week' ? 'seg-tab-active' : ''}}" 
        data-period="week" 
        bindtap="selectPeriod"
      >
        <text class="seg-text">周度</text>
      </view>
      <view 
        class="seg-tab {{currentPeriod === 'month' ? 'seg-tab-active' : ''}}" 
        data-period="month" 
        bindtap="selectPeriod"
      >
        <text class="seg-text">月度</text>
      </view>
      <view 
        class="seg-tab {{currentPeriod === 'year' ? 'seg-tab-active' : ''}}" 
        data-period="year" 
        bindtap="selectPeriod"
      >
        <text class="seg-text">年度</text>
      </view>
    </view>

    <view class="ai-summary-card">
      <view class="card-cover">
        <text class="cover-emoji">🌸</text>
        <text class="cover-period">{{periodLabel}}</text>
      </view>
      <view class="card-body">
        <view class="ai-label">
          <text class="ai-sparkle">✨</text>
          <text class="ai-label-text">AI {{periodName}}摘要</text>
        </view>
        <text class="summary-text">{{summaryText}}</text>

        <view class="divider"></view>

        <view class="themes-section">
          <text class="section-label">关键主题</text>
          <view class="theme-tags">
            <view class="theme-tag tag-orange">
              <text class="tag-emoji">📖</text>
              <text class="tag-text">阅读</text>
            </view>
            <view class="theme-tag tag-green">
              <text class="tag-emoji">🏃</text>
              <text class="tag-text">运动</text>
            </view>
            <view class="theme-tag tag-blue">
              <text class="tag-emoji">💼</text>
              <text class="tag-text">工作</text>
            </view>
          </view>
        </view>

        <view class="divider"></view>

        <view class="highlights-section">
          <text class="section-label">精彩集锦</text>
          <view class="highlight-item">
            <text class="highlight-dot">✦</text>
            <text class="highlight-text">完成了 Q2 项目报告，获得团队好评</text>
          </view>
          <view class="highlight-item">
            <text class="highlight-dot">✦</text>
            <text class="highlight-text">读完《小王子》，写下 3 段感悟笔记</text>
          </view>
          <view class="highlight-item">
            <text class="highlight-dot">✦</text>
            <text class="highlight-text">本周累计跑步 12 公里，保持运动习惯</text>
          </view>
        </view>
      </view>
    </view>

    <view class="mini-calendar">
      <view class="cal-header">
        <text class="cal-arrow" bindtap="prevMonth">‹</text>
        <text class="cal-title">{{calendarTitle}}</text>
        <text class="cal-arrow" bindtap="nextMonth">›</text>
      </view>
      <view class="cal-weekdays">
        <text class="cal-wd" wx:for="{{weekDays}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="cal-weeks">
        <view class="cal-week" wx:for="{{calendarDays}}" wx:key="weekIndex">
          <view 
            class="cal-day {{item2.isCurrentMonth ? '' : 'cal-day-other'}} {{item2.isToday ? 'cal-day-today' : ''}} {{item2.hasRecord ? 'cal-day-has' : ''}}" 
            wx:for="{{item.days}}" 
            wx:for-item="item2" 
            wx:key="day"
          >
            <text class="cal-day-text">{{item2.day || ''}}</text>
            <view wx:if="{{item2.hasRecord}}" class="cal-day-dot"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>
</view>