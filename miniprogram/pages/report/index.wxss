.container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 22rpx 120rpx;
  color: var(--aid-text);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-back,
.header-more {
  color: var(--aid-muted);
  font-size: 24rpx;
  font-weight: 800;
}

.header-title {
  font-size: 30rpx;
  font-weight: 900;
}

.hero {
  margin-top: 12rpx;
  border-radius: 32rpx;
  padding: 22rpx;
  background: linear-gradient(160deg, #24211d 0%, #3c342e 100%);
}

.hero-date {
  display: block;
  color: #ffffffcc;
  font-size: 20rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 8rpx;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.6;
  font-weight: 800;
}

.hero-chips {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
}

.hero-chip {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #ffffff1a;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.switch-bar {
  margin-top: 12rpx;
  display: flex;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  gap: 6rpx;
}

.switch-item {
  flex: 1;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  border-radius: 999rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.switch-item-active {
  background: #fff;
  color: var(--aid-text);
}

.content-swiper {
  margin-top: 12rpx;
  height: 980rpx;
}

.report-scroll {
  height: 980rpx;
}

.section {
  margin-bottom: 12rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 1rpx solid var(--aid-line);
  box-shadow: var(--aid-shadow);
  padding: 18rpx;
}

.section-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.timeline {
  padding: 4rpx 0 18rpx;
}

.timeline-day {
  margin: 16rpx 0 8rpx;
}

.timeline-day-text {
  font-size: 19rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.timeline-item {
  display: flex;
  gap: 12rpx;
  padding: 10rpx 0;
}

.timeline-left {
  width: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timeline-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #ff8a4b;
  margin-top: 10rpx;
}

.timeline-line {
  flex: 1;
  width: 2rpx;
  margin-top: 6rpx;
  background: rgba(230, 216, 196, 0.9);
}

.timeline-right {
  flex: 1;
  padding: 12rpx;
  border-radius: 18rpx;
  background: #fcfaf7;
}

.timeline-meta {
  display: flex;
  gap: 10rpx;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.timeline-time {
  font-size: 20rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.timeline-tag {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  color: var(--aid-muted);
  font-weight: 700;
}

.timeline-text {
  display: block;
  font-size: 23rpx;
  line-height: 1.66;
  white-space: pre-wrap;
  word-break: break-word;
}

.category-block {
  margin-bottom: 12rpx;
  padding: 12rpx;
  border: 1rpx solid var(--aid-line);
  border-radius: 20rpx;
  background: #fcfaf7;
}

.category-title {
  display: block;
  margin-bottom: 6rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.category-text {
  display: block;
  font-size: 23rpx;
  line-height: 1.68;
  white-space: pre-wrap;
  word-break: break-word;
}

.report-text {
  display: block;
  font-size: 23rpx;
  line-height: 1.72;
  white-space: pre-wrap;
  word-break: break-word;
}

.bottom-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
}

.copy-btn {
  flex: 1;
  height: 76rpx;
  margin: 0;
  border-radius: 16rpx;
  background: #ff8a4b;
  color: #fff;
  border: none;
  font-size: 24rpx;
  font-weight: 800;
}

.copy-btn::after {
  border: none;
}

.copy-btn-muted {
  background: #24211d0d;
  color: #24211d;
}
