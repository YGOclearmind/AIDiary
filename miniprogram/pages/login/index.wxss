.page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F2 0%, #FFEBD8 100%);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.bg-decor {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(232, 160, 64, 0.08);
}

.circle-1 {
  width: 600rpx;
  height: 600rpx;
  top: -200rpx;
  right: -150rpx;
}

.circle-2 {
  width: 400rpx;
  height: 400rpx;
  top: 100rpx;
  left: -100rpx;
}

.circle-3 {
  width: 300rpx;
  height: 300rpx;
  bottom: 200rpx;
  right: -80rpx;
}

.content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx 80rpx;
  flex: 1;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC80 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(232, 160, 64, 0.25);
  margin-bottom: 32rpx;
}

.logo-text {
  font-size: 80rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 800;
  color: #5D4E42;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #A09080;
}

.welcome-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #5D4E42;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #A09080;
}

.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 60rpx;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FFB74D 0%, #FF9800 100%);
  border-radius: 50rpx;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 152, 0, 0.3);
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  opacity: 0.7;
}

.login-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.policy-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
}

.policy-text {
  font-size: 22rpx;
  color: #A09080;
}

.policy-link {
  font-size: 22rpx;
  color: #E8A040;
}

.auth-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.auth-card {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 44rpx 40rpx;
  box-sizing: border-box;
}

.auth-title {
  font-size: 32rpx;
  color: #5D4E42;
  font-weight: 700;
}

.auth-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #A09080;
  line-height: 1.6;
}

.auth-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.auth-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-button-reset {
  margin: 0;
  padding: 0;
  line-height: 76rpx;
}

.auth-button-reset::after {
  border: none;
}

.auth-btn-primary {
  background: linear-gradient(135deg, #FFF5E6 0%, #FFECD2 100%);
  border: 2rpx solid rgba(232, 200, 144, 0.25);
}

.auth-btn-text {
  font-size: 26rpx;
  color: #A09080;
  font-weight: 600;
}

.auth-btn-text-primary {
  color: #E8A040;
}
