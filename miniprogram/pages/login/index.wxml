<view class="page">
  <view class="bg-decor">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>

  <view class="content">
    <view class="logo-area">
      <view class="logo">
        <text class="logo-text">📖</text>
      </view>
      <text class="app-name">随性日记</text>
      <text class="app-slogan">记录每一天的小确幸</text>
    </view>

    <view class="welcome-area">
      <text class="welcome-title">欢迎回来</text>
      <text class="welcome-desc">选择头像开启你的专属日记之旅</text>
    </view>

    <view class="action-area">
      <button class="login-btn" bindtap="onLoginTap">
        <view class="login-btn-inner">
          <text class="login-btn-text">授权微信头像</text>
        </view>
      </button>
    </view>

    <view class="policy-area">
      <text class="policy-text">登录即表示同意</text>
      <text class="policy-link" bindtap="onUserAgreement">《用户协议》</text>
      <text class="policy-text">和</text>
      <text class="policy-link" bindtap="onPrivacyPolicy">《隐私政策》</text>
    </view>
  </view>

  <view wx:if="{{showAvatarAuth}}" class="auth-mask">
    <view class="auth-card">
      <text class="auth-title">授权获取头像</text>
      <text class="auth-desc">用于在首页右上角展示你的微信头像</text>
      <view class="auth-actions">
        <button class="auth-btn auth-btn-primary auth-button-reset" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <text class="auth-btn-text auth-btn-text-primary">立即授权</text>
        </button>
      </view>
    </view>
  </view>
</view>
