<view class="container">
  <view class="card profile-card">
    <view class="profile-top">
      <view class="user-box">
        <view class="avatar-gradient">S</view>
        <view class="user-details">
          <text class="user-name">随性同学</text>
          <text class="user-id">已同步 · {{userOpenid || '最近备份：今天 08:12'}}</text>
        </view>
      </view>
      <text class="member-chip">会员未开通</text>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-label">总记录</text>
        <text class="stat-value">{{recordCount}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">语音记录</text>
        <text class="stat-value">{{audioCount}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">报告</text>
        <text class="stat-value">{{summaryCount}}</text>
      </view>
    </view>
  </view>

  <view class="switch-bar">
    <view class="switch-item {{currentTab === 'stats' ? 'switch-item-active' : ''}}" data-tab="stats" data-index="0" bindtap="switchMineTab">统计</view>
    <view class="switch-item {{currentTab === 'settings' ? 'switch-item-active' : ''}}" data-tab="settings" data-index="1" bindtap="switchMineTab">设置</view>
    <view class="switch-item {{currentTab === 'about' ? 'switch-item-active' : ''}}" data-tab="about" data-index="2" bindtap="switchMineTab">关于</view>
  </view>

  <swiper class="content-swiper" current="{{currentTabIndex}}" bindchange="onTabSwiperChange" duration="260">
    <swiper-item>
      <view class="card panel-card">
        <text class="section-title">数据概览</text>
        <view class="stats-row">
          <view class="stat-item">
            <text class="stat-label">总记录</text>
            <text class="stat-value">{{recordCount}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">语音记录</text>
            <text class="stat-value">{{audioCount}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">生成总结</text>
            <text class="stat-value">{{summaryCount}}</text>
          </view>
        </view>
      </view>
    </swiper-item>

    <swiper-item>
      <view class="card panel-card">
        <text class="section-title">偏好设置</text>
        <view class="setting-list">
          <view class="setting-item">
            <text class="setting-label">默认模板</text>
            <text class="setting-arrow">三句话 ></text>
          </view>
          <view class="setting-item">
            <text class="setting-label">夜间模式</text>
            <text class="auto-chip">自动</text>
          </view>
          <view class="setting-item">
            <text class="setting-label">隐私锁</text>
            <text class="setting-arrow">未开启 ></text>
          </view>
        </view>
        <text class="section-title section-gap">数据</text>
        <button class="action-btn action-btn-primary" bindtap="exportData">导出为 PDF / Markdown</button>
        <button class="action-btn" bindtap="clearRecords">清空记录</button>
        <button class="action-btn" bindtap="seedMockData">生成三年示例数据</button>
      </view>
    </swiper-item>

    <swiper-item>
      <view class="card panel-card">
        <text class="about-title">AI 流水账 v1.0.0</text>
        <text class="about-desc">让记录更简单，让生活更美好。</text>
        <text class="about-desc">支持文字与语音记录、日报周报年报生成、历史报告管理。</text>
        <button class="action-btn" bindtap="about">弹窗查看关于</button>
      </view>
    </swiper-item>
  </swiper>
</view>
