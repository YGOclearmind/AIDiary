.container {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 22rpx 120rpx;
  box-sizing: border-box;
  color: var(--aid-text);
}

.card {
  border-radius: 32rpx;
  background: #fff;
  border: 1rpx solid var(--aid-line);
  box-shadow: var(--aid-shadow);
  padding: 20rpx;
}

.profile-card {
  border-radius: 34rpx;
}

.profile-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.user-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar-gradient {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ff8a4b 0%, #5b8a6b 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
}

.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 4rpx;
}

.user-id {
  display: block;
  font-size: 20rpx;
  color: var(--aid-muted);
  line-height: 1.5;
}

.member-chip {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #ff8a4b1a;
  color: #ff8a4b;
  font-size: 20rpx;
  font-weight: 800;
}

.stats-row {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.stat-item {
  flex: 1;
  border-radius: 20rpx;
  background: #fcfaf7;
  padding: 12rpx;
}

.stat-label {
  display: block;
  color: var(--aid-muted);
  font-size: 20rpx;
  font-weight: 700;
}

.stat-value {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.switch-bar {
  margin-top: 12rpx;
  display: flex;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  gap: 6rpx;
}

.switch-item {
  flex: 1;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  border-radius: 999rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.switch-item-active {
  background: #fff;
  color: var(--aid-text);
}

.content-swiper {
  margin-top: 12rpx;
  height: 760rpx;
}

.panel-card {
  min-height: 680rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 800;
}

.section-gap {
  margin-top: 16rpx;
  display: block;
}

.setting-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--aid-line);
}

.setting-label {
  font-size: 24rpx;
  font-weight: 700;
}

.setting-arrow {
  font-size: 22rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.auto-chip {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  font-size: 20rpx;
  font-weight: 700;
}

.action-btn {
  width: 100%;
  height: 72rpx;
  margin: 10rpx 0 0;
  border-radius: 16rpx;
  background: #24211d0d;
  color: #24211d;
  font-size: 23rpx;
  font-weight: 800;
}

.action-btn-primary {
  background: #ff8a4b;
  color: #fff;
}

.action-btn::after {
  border: none;
}

.about-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.about-desc {
  display: block;
  font-size: 22rpx;
  color: #4a453f;
  line-height: 1.7;
  margin-bottom: 8rpx;
  font-weight: 600;
}
