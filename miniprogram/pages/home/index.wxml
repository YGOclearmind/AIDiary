<view class="page">
  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="false" scroll-x="false" enable-flex>
    <view class="header-row">
      <view class="header-left">
        <text class="greeting">{{greetingText}}</text>
        <text class="date-title">{{dateTitle}}</text>
      </view>
      <view class="avatar">
        <text class="avatar-text">S</text>
      </view>
    </view>

    <view class="ai-card">
      <view class="ai-card-header">
        <text class="ai-sparkle">✨</text>
        <text class="ai-title">AI 日常精选</text>
      </view>
      <text class="ai-summary">{{aiSummaryText}}</text>
    </view>

    <view class="timeline-header">
      <text class="timeline-title">今日记录</text>
      <text class="timeline-count">{{todayRecords.length}} 条笔记</text>
    </view>

    <view class="timeline-feed">
      <view class="timeline-dots">
        <view 
          wx:for="{{todayRecords}}" 
          wx:key="_id" 
          class="dot-col"
        >
          <view class="dot {{index === 0 ? 'dot-active' : ''}}"></view>
          <view wx:if="{{index < todayRecords.length - 1}}" class="dot-line"></view>
        </view>
      </view>
      <view class="timeline-cards">
        <view 
          wx:for="{{todayRecords}}" 
          wx:key="_id" 
          class="entry-card"
        >
          <text class="entry-time">{{item.timeText}}</text>
          <text class="entry-text">{{item.contentText}}</text>
          <view wx:if="{{item.category}}" class="entry-tag">
            <text class="entry-tag-text">{{item.category}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{todayRecords.length === 0}}" class="empty-hint">
      <text class="empty-hint-text">今天还没有记录，写下你的第一条吧 ✍️</text>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>

  <view class="input-bar">
    <view class="input-row">
      <view class="add-btn" bindtap="onAddTap">
        <text class="add-icon">+</text>
      </view>
      <input
        class="text-input"
        placeholder="记录此刻的想法..."
        placeholder-class="input-placeholder"
        bindinput="onInputChange"
        bindconfirm="onInputConfirm"
        value="{{inputValue}}"
        confirm-type="done"
      />
      <view class="date-btn" bindtap="onDateTap">
        <text class="date-btn-icon">📅</text>
        <text class="date-btn-text">{{dateBtnLabel}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showInputModal}}" class="modal-mask" bindtap="closeInputModal">
    <view class="modal-content" catchtap="preventTap">
      <view class="modal-header">
        <text class="modal-title">写一条记录</text>
        <view class="modal-close" bindtap="closeInputModal">×</view>
      </view>
      <textarea
        class="modal-textarea"
        placeholder="写一句也行，描述、吐槽、许愿、记录灵感…"
        placeholder-class="modal-placeholder"
        bindinput="onModalInput"
        value="{{modalInputValue}}"
        maxlength="-1"
        auto-height
        focus="{{showInputModal}}"
      ></textarea>
      <view class="modal-actions">
        <button class="modal-btn modal-btn-voice" bindtap="toggleVoiceInput">
          <text class="modal-btn-icon">🎤</text>
          <text class="modal-btn-text">{{isRecording ? '结束' : '语音'}}</text>
        </button>
        <button class="modal-btn modal-btn-save" bindtap="saveRecord">保存</button>
      </view>
      <text wx:if="{{voiceStatus}}" class="voice-status">{{voiceStatus}}</text>
    </view>
  </view>
</view>