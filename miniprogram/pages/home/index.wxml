<view class="page">
  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="false" scroll-x="false" enable-flex>
    <view class="header-row">
      <view class="header-left">
        <text class="greeting">{{greetingText}}</text>
        <text class="date-title">{{dateTitle}}</text>
      </view>
      <view class="avatar" bindtap="onAvatarTap">
        <image wx:if="{{hasAvatarImage}}" class="avatar-img" src="{{avatarDisplayUrl}}" mode="aspectFill" binderror="onAvatarImgError" />
        <text wx:else class="avatar-text">S</text>
      </view>
    </view>

    <view class="ai-card">
      <view class="ai-card-header">
        <text class="ai-sparkle">✨</text>
        <text class="ai-title">AI 日常精选</text>
      </view>
      <text class="ai-summary">{{aiSummaryText}}</text>
    </view>

    <view class="timeline-header">
      <text class="timeline-title">当日记录</text>
      <text class="timeline-count">{{todayRecords.length}} 条笔记</text>
    </view>

    <view class="timeline-feed">
      <view 
        wx:for="{{todayRecords}}" 
        wx:key="_id" 
        class="timeline-row"
      >
        <view class="timeline-dot-col">
          <view class="dot {{index === 0 ? 'dot-active' : ''}}"></view>
          <view wx:if="{{index < todayRecords.length - 1}}" class="dot-line"></view>
        </view>
        <view class="entry-card">
          <text class="entry-time">{{item.timeText}}</text>
          <text class="entry-text">{{item.contentText}}</text>
          <view wx:if="{{item.category}}" class="entry-tag">
            <text class="entry-tag-text">{{item.category}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{todayRecords.length === 0}}" class="empty-hint">
      <text class="empty-hint-text">今天还没有记录，写下你的第一条吧 ✍️</text>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>

  <view class="input-bar">
    <view class="input-row">
      <view class="date-btn" bindtap="openCalendar">
        <text class="date-btn-icon">📅</text>
        <text class="date-btn-text">{{dateBtnLabel}}</text>
      </view>
      <input
        class="text-input"
        placeholder="记录此刻的想法..."
        placeholder-class="input-placeholder"
        bindinput="onInputChange"
        bindconfirm="onInputConfirm"
        value="{{inputValue}}"
        confirm-type="done"
      />
      <view wx:if="{{inputValue}}" class="submit-btn" bindtap="onSubmitTap">
        <text class="submit-btn-text">完成</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showCalendar}}" class="cal-mask" bindtap="closeCalendar">
    <view class="cal-popup" catchtap="preventTap">
      <view class="cal-header">
        <text class="cal-arrow" bindtap="calPrevMonth">‹</text>
        <view class="cal-title-wrap">
          <text class="cal-title">{{calTitle}}</text>
          <text class="cal-today-btn" bindtap="goToToday">返回今日</text>
        </view>
        <text class="cal-arrow" bindtap="calNextMonth">›</text>
      </view>
      <view class="cal-weekdays">
        <text class="cal-wd" wx:for="{{calWeekDays}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="cal-weeks">
        <view class="cal-week" wx:for="{{calDays}}" wx:key="weekIndex">
          <view 
            class="cal-day {{item2.isCurrentMonth ? '' : 'cal-day-other'}} {{item2.isToday ? 'cal-day-today' : ''}} {{item2.isSelected ? 'cal-day-selected' : ''}} {{item2.hasRecord ? 'cal-day-has' : ''}} {{item2.isFuture ? 'cal-day-future' : ''}}" 
            wx:for="{{item.days}}" 
            wx:for-item="item2" 
            wx:key="day"
            bindtap="onCalDayTap"
            data-date="{{item2.dateStr}}"
            data-current="{{item2.isCurrentMonth}}"
            data-future="{{item2.isFuture}}"
          >
            <text class="cal-day-text">{{item2.day || ''}}</text>
            <view wx:if="{{item2.hasRecord}}" class="cal-day-dot"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showAvatarAuth}}" class="auth-mask">
    <view class="auth-card">
      <text class="auth-title">授权获取头像</text>
      <text class="auth-desc">用于在右上角展示你的微信头像</text>
      <view class="auth-actions">
        <button class="auth-btn auth-btn-primary auth-button-reset" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <text class="auth-btn-text auth-btn-text-primary">立即授权</text>
        </button>
        <button class="auth-btn auth-btn-ghost auth-button-reset" bindtap="closeAvatarAuth">
          <text class="auth-btn-text">稍后再说</text>
        </button>
      </view>
    </view>
  </view>
</view>
