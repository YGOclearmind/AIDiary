.page {
  width: 100%;
  min-height: 100vh;
  background: var(--warm-bg);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow-x: hidden;
}

.scroll-area {
  flex: 1;
  padding: 88rpx 40rpx 0;
  box-sizing: border-box;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 0;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.greeting {
  font-size: 28rpx;
  color: var(--warm-text-muted);
  font-weight: 400;
}

.date-title {
  font-size: 44rpx;
  color: var(--warm-text);
  font-weight: 700;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #E8DDD0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 28rpx;
  color: var(--warm-text-muted);
  font-weight: 600;
}

.ai-card {
  margin-top: 40rpx;
  padding: 40rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #FFF5E6 0%, #FFECD2 50%, #FFE0B8 100%);
  border: 2rpx solid rgba(232, 200, 144, 0.19);
  box-shadow: 0 8rpx 32rpx rgba(212, 196, 176, 0.12);
}

.ai-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ai-sparkle {
  font-size: 28rpx;
}

.ai-title {
  font-size: 28rpx;
  color: var(--warm-accent-dark);
  font-weight: 600;
}

.ai-summary {
  font-size: 26rpx;
  color: #6D5D4D;
  line-height: 1.6;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 40rpx;
}

.timeline-title {
  font-size: 32rpx;
  color: var(--warm-text);
  font-weight: 600;
}

.timeline-count {
  font-size: 24rpx;
  color: var(--warm-text-muted);
}

.timeline-feed {
  display: flex;
  flex-direction: column;
  margin-top: 24rpx;
}

.timeline-row {
  display: flex;
  gap: 20rpx;
}

.timeline-dot-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 10rpx;
  background: #D4C4B0;
  flex-shrink: 0;
}

.dot-active {
  background: var(--warm-accent);
}

.dot-line {
  flex: 1;
  width: 4rpx;
  background: #E8DDD0;
}

.entry-card {
  flex: 1;
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--warm-bg-card);
  box-shadow: 0 4rpx 16rpx rgba(212, 196, 176, 0.09);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.entry-time {
  font-size: 22rpx;
  color: var(--warm-text-light);
  font-weight: 500;
}

.entry-text {
  font-size: 26rpx;
  color: #4A4038;
  line-height: 1.55;
  word-break: break-word;
}

.entry-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.entry-tag-text {
  font-size: 20rpx;
  color: #C0A880;
  font-weight: 500;
}

.empty-hint {
  padding: 80rpx 0;
  text-align: center;
}

.empty-hint-text {
  font-size: 26rpx;
  color: var(--warm-text-muted);
}

.bottom-spacer {
  height: 180rpx;
}

.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFDFB;
  border-top: 2rpx solid rgba(232, 221, 208, 0.12);
  box-shadow: 0 -4rpx 24rpx rgba(212, 196, 176, 0.08);
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  height: 92rpx;
}

.submit-btn {
  padding: 0 28rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #FFF5E6 0%, #FFECD2 100%);
  border: 2rpx solid rgba(232, 200, 144, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.submit-btn-text {
  font-size: 26rpx;
  color: var(--warm-accent-dark);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.text-input {
  flex: 1;
  height: 76rpx;
  padding: 0 32rpx;
  border-radius: 38rpx;
  background: var(--warm-bg-input);
  font-size: 26rpx;
  color: var(--warm-text);
}

.input-placeholder {
  color: var(--warm-text-placeholder);
  font-size: 26rpx;
}

.date-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  background: var(--warm-bg-input);
  flex-shrink: 0;
}

.date-btn-icon {
  font-size: 24rpx;
}

.date-btn-text {
  font-size: 24rpx;
  color: #6D5D4D;
  font-weight: 500;
}

.cal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.cal-popup {
  width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.cal-arrow {
  font-size: 36rpx;
  color: var(--warm-text-muted);
  padding: 8rpx 20rpx;
}

.cal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--warm-text);
}

.cal-weekdays {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.cal-wd {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #C0B0A0;
  font-weight: 500;
}

.cal-weeks {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cal-week {
  display: flex;
  justify-content: space-around;
}

.cal-day {
  flex: 1;
  height: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 16rpx;
}

.cal-day-text {
  font-size: 26rpx;
  color: #5A5048;
}

.cal-day-other .cal-day-text {
  color: #C0B0A0;
}

.cal-day-today .cal-day-text {
  color: var(--warm-accent);
  font-weight: 700;
}

.cal-day-selected {
  background: linear-gradient(135deg, #FFF5E6 0%, #FFECD2 100%);
}

.cal-day-selected .cal-day-text {
  color: var(--warm-accent-dark);
  font-weight: 700;
}

.cal-day-has .cal-day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: var(--warm-accent);
  position: absolute;
  bottom: 4rpx;
}