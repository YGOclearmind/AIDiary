.container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 22rpx 120rpx;
  color: var(--aid-text);
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
}

.subtitle {
  display: block;
  margin-top: 6rpx;
  color: var(--aid-muted);
  font-size: 24rpx;
  font-weight: 600;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 28rpx;
  background: #24211d0d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.streak-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.streak-text {
  color: var(--aid-muted);
  font-size: 22rpx;
  font-weight: 600;
}

.chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  font-size: 22rpx;
  font-weight: 700;
}

.chip-orange {
  background: #ff8a4b1a;
  color: #ff8a4b;
}

.mood-row {
  margin-top: 12rpx;
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.card {
  margin-top: 14rpx;
  border-radius: 36rpx;
  background: #fff;
  border: 1rpx solid var(--aid-line);
  box-shadow: var(--aid-shadow);
  padding: 24rpx;
}

.quick-card {
  border-radius: 40rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 800;
}

.card-meta {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  color: var(--aid-muted);
  font-size: 21rpx;
  font-weight: 700;
}

.input-area {
  width: 100%;
  height: 220rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #fcfaf7;
  padding: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.action-row {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
}

.btn {
  flex: 1;
  height: 76rpx;
  margin: 0;
  border-radius: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #ff8a4b;
  color: #fff;
}

.btn-muted {
  background: #24211d0d;
  color: #24211d;
}

.tiles-row {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.tile {
  flex: 1;
  background: #fff;
  border: 1rpx solid var(--aid-line);
  border-radius: 32rpx;
  box-shadow: var(--aid-shadow);
  padding: 22rpx;
}

.tile-title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
}

.tile-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--aid-muted);
  font-size: 21rpx;
  line-height: 1.5;
}

.tile-btn {
  margin: 14rpx 0 0;
  height: 64rpx;
  border-radius: 20rpx;
  background: #24211d0d;
  color: #24211d;
  font-size: 22rpx;
  font-weight: 800;
}

.tile-btn-accent {
  background: #ff8a4b;
  color: #fff;
}

.tile-btn::after {
  border: none;
}

.highlight {
  margin-top: 14rpx;
  border-radius: 40rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ffe2d2 0%, #e7f2ff 55%, #eaf7ee 100%);
}

.highlight-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
}

.highlight-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.68;
  font-weight: 700;
}

.highlight-sub {
  display: block;
  margin-top: 8rpx;
  color: #5b544d;
  font-size: 22rpx;
  line-height: 1.6;
}

.state-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5b544d;
}

.btn-white {
  background: #ffffffaa;
  color: #24211d;
}

.btn-dark {
  background: #24211d;
  color: #fff;
}

.timeline-card {
  margin-top: 14rpx;
}

.chip-wrap {
  display: flex;
  gap: 6rpx;
}

.chip-count {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  color: var(--aid-muted);
  font-size: 18rpx;
  font-weight: 700;
}

.timeline-row {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.timeline-list {
  margin-top: 6rpx;
}

.timeline-item {
  margin-top: 8rpx;
  display: flex;
  align-items: stretch;
  gap: 10rpx;
}

.timeline-marker {
  width: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dot {
  margin-top: 10rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff8a4b;
}

.timeline-line {
  margin-top: 8rpx;
  width: 2rpx;
  flex: 1;
  background: #ff8a4b4d;
}

.timeline-main {
  flex: 1;
  padding-bottom: 14rpx;
}

.timeline-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.timeline-time {
  font-size: 22rpx;
  font-weight: 800;
  color: #24211d;
}

.timeline-day {
  font-size: 20rpx;
  color: var(--aid-muted);
  font-weight: 700;
}

.timeline-text {
  flex: 1;
  font-size: 23rpx;
  line-height: 1.65;
  color: #3d3934;
}

