.page {
  width: 100%;
  min-height: 100vh;
  background: #FFF9F2;
}

.scroll-area {
  width: 100%;
  min-height: 100vh;
}

.content {
  padding: 40rpx;
}

.title-area {
  text-align: center;
  padding: 40rpx 0 60rpx;
  border-bottom: 2rpx solid #E8DDD0;
  margin-bottom: 40rpx;
}

.main-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #5D4E42;
  display: block;
  margin-bottom: 16rpx;
}

.version {
  font-size: 24rpx;
  color: #A09080;
}

.section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5D4E42;
  margin-bottom: 24rpx;
  display: block;
}

.paragraph {
  margin-bottom: 20rpx;
}

.para-text {
  font-size: 28rpx;
  color: #6D5D4D;
  line-height: 1.7;
}

.sub-list {
  padding-left: 32rpx;
  margin-top: 12rpx;
}

.list-item {
  font-size: 28rpx;
  color: #6D5D4D;
  line-height: 1.7;
  display: block;
  margin-bottom: 8rpx;
}

.bottom-spacer {
  height: 80rpx;
}
