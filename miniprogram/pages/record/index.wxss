.container {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 22rpx 120rpx;
  box-sizing: border-box;
  color: var(--aid-text);
}

.title {
  font-size: 44rpx;
  font-weight: 800;
}

.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  color: #24211d;
  font-size: 21rpx;
  font-weight: 700;
}

.switch-bar {
  margin-top: 12rpx;
  display: flex;
  gap: 8rpx;
}

.switch-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #24211d;
  background: #24211d0d;
  font-weight: 700;
}

.switch-item-active {
  background: #ff8a4b1a;
  color: #ff8a4b;
}

.template-row {
  margin-top: 12rpx;
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  color: #24211d;
  font-size: 21rpx;
  font-weight: 800;
}

.chip-active {
  background: #ff8a4b1a;
  color: #ff8a4b;
}

.content-swiper {
  margin-top: 12rpx;
  height: 980rpx;
}

.card {
  border-radius: 32rpx;
  background: #fff;
  border: 1rpx solid var(--aid-line);
  box-shadow: var(--aid-shadow);
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.row-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 800;
}

.card-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--aid-muted);
  font-weight: 600;
}

.date-picker-trigger {
  min-width: 150rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
}

.date-value {
  font-size: 21rpx;
  font-weight: 700;
}

.date-arrow {
  font-size: 20rpx;
  color: var(--aid-muted);
}

.input-wrap {
  position: relative;
}

.input-area {
  width: 100%;
  height: 260rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #fcfaf7;
  font-size: 24rpx;
  line-height: 1.7;
}

.input-tip {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  z-index: 2;
  max-width: 320rpx;
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  background: #24211ddd;
  color: #fff;
  font-size: 20rpx;
}

.meta-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meta-tags {
  display: flex;
  gap: 8rpx;
}

.meta-chip {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #eaf7ee;
  color: #5b8a6b;
  font-size: 20rpx;
  font-weight: 700;
}

.meta-chip-blue {
  background: #e7f2ff;
  color: #2f6daa;
}

.counter {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #24211d0d;
  font-size: 20rpx;
  font-weight: 700;
}

.action-row {
  margin-top: 12rpx;
  display: flex;
  gap: 8rpx;
}

.btn,
.audio-play-btn,
.record-bottom-btn {
  background: #24211d0d;
  color: #24211d;
}

.btn::after,
.audio-play-btn::after,
.record-bottom-btn::after {
  border: none;
}

.btn {
  margin: 0;
  flex: 1;
  height: 68rpx;
  border-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.btn-primary {
  background: #ff8a4b;
  color: #fff;
}

.btn-muted {
  background: #24211d0d;
  color: #24211d;
}

.btn-recording {
  background: #24211d;
  color: #fff;
}

.voice-status {
  margin-top: 10rpx;
  display: block;
  font-size: 21rpx;
  color: var(--aid-muted);
}

.draft-item {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.empty-text {
  margin-top: 8rpx;
  color: var(--aid-muted);
  font-size: 22rpx;
}

.records-scroll {
  max-height: 760rpx;
}

.inspire-card {
  background: linear-gradient(135deg, #ffe2d2 0%, #e7f2ff 55%, #eaf7ee 100%);
}

.state-text {
  font-size: 22rpx;
  color: #4b463f;
}

.state-text-error {
  color: #b42318;
}

.inspiration-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.inspiration-block {
  padding: 14rpx;
  border-radius: 18rpx;
  background: #ffffffaa;
}

.inspiration-label {
  display: block;
  margin-bottom: 6rpx;
  font-size: 20rpx;
  color: var(--aid-muted);
}

.inspiration-text {
  font-size: 23rpx;
  line-height: 1.7;
  word-break: break-word;
}

.record-item {
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid var(--aid-line);
  background: transparent;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item-selected {
  background: #24211d08;
  border-radius: 18rpx;
}

.record-item-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.audio-record-row,
.record-text-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
}

.record-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.audio-play-btn {
  width: 76rpx;
  min-width: 76rpx;
  height: 44rpx;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 14rpx;
  font-size: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.record-bottom-actions {
  position: sticky;
  bottom: 14rpx;
  z-index: 8;
  margin-top: 4rpx;
  display: flex;
  gap: 10rpx;
  padding: 12rpx;
  border-radius: 18rpx;
  background: #ffffffcc;
  border: 1rpx solid var(--aid-line);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.12);
}

.record-bottom-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.record-bottom-btn-delete {
  background: #ff8a4b1a;
  color: #ff8a4b;
}

.audio-play-btn-active {
  background: #24211d;
  color: #fff;
}

.record-item-text {
  width: 100%;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.68;
  word-break: break-word;
}

.audio-record-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.audio-record-title {
  font-size: 23rpx;
  font-weight: 700;
}

.audio-record-desc,
.audio-record-note,
.record-item-time {
  font-size: 20rpx;
  color: var(--aid-muted);
}

.audio-record-note {
  line-height: 1.6;
}

.empty-state {
  padding: 50rpx 18rpx;
  text-align: center;
}

.empty-title {
  display: block;
  margin-top: 8rpx;
  font-size: 25rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--aid-muted);
  line-height: 1.6;
}

.summary-modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
}

.summary-modal-content {
  width: 90%;
  max-width: 700rpx;
  max-height: 80vh;
  border: 1rpx solid var(--aid-line);
  border-radius: 18rpx;
  background: #fff;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.summary-modal-header {
  padding: 22rpx;
  border-bottom: 1rpx solid var(--aid-line);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-modal-title {
  font-size: 28rpx;
  font-weight: 800;
}

.summary-modal-close {
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid var(--aid-line);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.summary-modal-body {
  flex: 1;
  padding: 30rpx;
  max-height: 50vh;
  overflow: auto;
  box-sizing: border-box;
}

.summary-modal-text {
  font-size: 24rpx;
  line-height: 1.75;
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: break-word;
  word-wrap: break-word;
  hyphens: auto;
  width: 100%;
  box-sizing: border-box;
}
